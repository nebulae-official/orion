# Orion Configuration
# Copy this file to .env and update values for your environment

# Application
APP_ENV=development

# Gateway
GATEWAY_PORT=8000
ORION_JWT_SECRET=  # REQUIRED in production - generate with: openssl rand -base64 32
# Deprecated: users are now managed in the Identity service database
# ORION_ADMIN_USER=admin
# ORION_ADMIN_PASS=
ORION_CORS_ORIGINS=http://localhost:3000  # Comma-separated allowed origins
ORION_ENCRYPTION_KEY=  # REQUIRED - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Database (use 'postgres' for Docker, 'localhost' for local dev)
POSTGRES_USER=orion
POSTGRES_PASSWORD=  # REQUIRED - use a strong password
POSTGRES_DB=orion
DATABASE_URL=postgresql+asyncpg://orion:YOUR_PASSWORD@postgres:5432/orion

# Redis (use 'redis' for Docker, 'localhost' for local dev)
REDIS_PASSWORD=redisdev
REDIS_URL=redis://:redisdev@redis:6379/0

# Milvus (use 'milvus' for Docker, 'localhost' for local dev)
# Authentication is enabled — default credentials: root / Milvus
# Change the root password after first login via Milvus CLI or Attu
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Services
SCOUT_URL=http://scout:8001
DIRECTOR_URL=http://director:8002
MEDIA_URL=http://media:8003
EDITOR_URL=http://editor:8004
PULSE_URL=http://pulse:8005
PUBLISHER_URL=http://publisher:8006

# Identity Service
IDENTITY_URL=http://identity:8007

# Dashboard
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# AI Providers (configure as needed)
OLLAMA_URL=http://ollama:11434
COMFYUI_URL=http://comfyui:8188

# OAuth (optional — leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# ── Database Tools ──
PGADMIN_EMAIL=admin@orion.local
PGADMIN_PASSWORD=orion_dev

# Databasus backup dashboard: http://localhost:4005
# Configure backups via web UI after first start

# Email (optional — stubs used if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@orion.local
